# Copy this to .env.local and fill in your values

# Password to access /waitlist admin page
WAITLIST_PASSWORD=your-secret-password

# Resend API key — get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Vercel Blob token — auto-added when you create a Blob store in Vercel dashboard
# Storage → Create Database → Blob → connect to this project
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx
